#!/usr/bin/env bash

# AR.IO Gateway - Parquet Export CLI
# Thin wrapper around the admin API for Parquet export.
# All core export logic lives in src/workers/parquet-exporter.ts.

# Load common library
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/lib/common.sh"

set -euo pipefail

usage() {
  cat <<USAGE
Usage: $0 --start-height N --end-height N [options]

Options:
  --output-dir DIR             Output directory (default: data/datasets/default)
  --start-height N             Start block height (required)
  --end-height N               End block height (required)
  --height-partition-size N    Blocks per partition (default: 1000)
  --max-file-rows N            Max rows per Parquet file (default: 1000000)
  --exclude-l1                 Exclude L1 transactions and tags
  --api-host HOST              Admin API host (default: localhost)
  --api-port PORT              Admin API port (default: 4000)
  --poll-interval N            Status poll interval in seconds (default: 5)
  --staging-job-dir DIR        Override output dir with staging job directory

  Iceberg Metadata:
  --generate-iceberg           Generate Apache Iceberg metadata after export
  --iceberg-root URI           Warehouse root URI for Iceberg metadata

  Verification:
  --verify-count               Verify row counts after export (requires duckdb and sqlite3 CLIs)

  -h, --help                   Show this help message
USAGE
}

# Configuration defaults
OUTPUT_DIR=""
STAGING_JOB_DIR=""
START_HEIGHT=""
END_HEIGHT=""
HEIGHT_PARTITION_SIZE=1000
MAX_FILE_ROWS=1000000
INCLUDE_L1=true
API_HOST="${ADMIN_API_HOST:-localhost}"
API_PORT="${ADMIN_API_PORT:-4000}"
POLL_INTERVAL=5
GENERATE_ICEBERG=false
ICEBERG_ROOT=""
VERIFY_COUNT=false

# Check required commands (python3 is used for JSON parsing in status polling)
require_commands python3 || exit 1

# Load environment configuration
load_env
load_admin_api_key

# Parse arguments
while [[ $# -gt 0 ]]; do
  case $1 in
    --output-dir)
      OUTPUT_DIR=$2
      shift 2
      ;;
    --start-height)
      START_HEIGHT=$2
      shift 2
      ;;
    --end-height)
      END_HEIGHT=$2
      shift 2
      ;;
    --height-partition-size)
      HEIGHT_PARTITION_SIZE=$2
      shift 2
      ;;
    --max-file-rows)
      MAX_FILE_ROWS=$2
      shift 2
      ;;
    --exclude-l1)
      INCLUDE_L1=false
      shift 1
      ;;
    --api-host)
      API_HOST=$2
      shift 2
      ;;
    --api-port)
      API_PORT=$2
      shift 2
      ;;
    --poll-interval)
      POLL_INTERVAL=$2
      shift 2
      ;;
    --generate-iceberg)
      GENERATE_ICEBERG=true
      shift 1
      ;;
    --iceberg-root)
      ICEBERG_ROOT="$2"
      shift 2
      ;;
    --verify-count)
      VERIFY_COUNT=true
      shift 1
      ;;
    --staging-job-dir)
      STAGING_JOB_DIR=$2
      shift 2
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      echo "Unknown option: $1" >&2
      usage
      exit 1
      ;;
  esac
done

# Validate required arguments
if [[ -z "$START_HEIGHT" || -z "$END_HEIGHT" ]]; then
  echo "Error: Must specify --start-height and --end-height" >&2
  usage
  exit 1
fi

# --staging-job-dir takes priority over --output-dir so callers
# (e.g. clickhouse-auto-import) that pass both get files where expected.
if [[ -n "$STAGING_JOB_DIR" ]]; then
  OUTPUT_DIR="$STAGING_JOB_DIR"
elif [[ -z "$OUTPUT_DIR" ]]; then
  OUTPUT_DIR="${LOCAL_DATASETS_PATH:-data/datasets}/default"
fi

# Validate numeric arguments
for v in "$START_HEIGHT" "$END_HEIGHT" "$HEIGHT_PARTITION_SIZE" "$MAX_FILE_ROWS"; do
  [[ $v =~ ^[0-9]+$ ]] || { echo "Error: Non-numeric argument detected: $v" >&2; exit 1; }
done

if (( START_HEIGHT > END_HEIGHT )); then
  echo "Error: startHeight ($START_HEIGHT) cannot be greater than endHeight ($END_HEIGHT)" >&2
  exit 1
fi

# Validate admin API key
if [[ -z "${ADMIN_API_KEY:-}" ]]; then
  echo "Error: ADMIN_API_KEY not set. Set it in .env or via ADMIN_API_KEY_FILE." >&2
  exit 1
fi

API_BASE="http://${API_HOST}:${API_PORT}"

# Build JSON body
SKIP_L1_TX=false
SKIP_L1_TAGS=false
if [[ "$INCLUDE_L1" == "false" ]]; then
  SKIP_L1_TX=true
  SKIP_L1_TAGS=true
fi

JSON_BODY=$(cat <<EOF
{
  "outputDir": "$OUTPUT_DIR",
  "startHeight": $START_HEIGHT,
  "endHeight": $END_HEIGHT,
  "heightPartitionSize": $HEIGHT_PARTITION_SIZE,
  "maxFileRows": $MAX_FILE_ROWS,
  "skipL1Transactions": $SKIP_L1_TX,
  "skipL1Tags": $SKIP_L1_TAGS
}
EOF
)

# Start the export
echo "Starting Parquet export via admin API..."
echo "  Heights: $START_HEIGHT - $END_HEIGHT"
echo "  Partition size: $HEIGHT_PARTITION_SIZE"
echo "  Output dir: $OUTPUT_DIR"

BODY_FILE=$(mktemp)
HTTP_CODE=$(curl -s -w "%{http_code}" -o "$BODY_FILE" -X POST \
  "${API_BASE}/ar-io/admin/export-parquet" \
  -H "Authorization: Bearer ${ADMIN_API_KEY}" \
  -H "Content-Type: application/json" \
  -d "$JSON_BODY")
BODY=$(cat "$BODY_FILE")
rm -f "$BODY_FILE"

if [[ "$HTTP_CODE" != "200" ]]; then
  echo "Error: Failed to start export (HTTP $HTTP_CODE): $BODY" >&2
  exit 1
fi

echo "Export started. Polling for completion..."

# Poll for status
while true; do
  sleep "$POLL_INTERVAL"

  BODY_FILE=$(mktemp)
  HTTP_CODE=$(curl -s -w "%{http_code}" -o "$BODY_FILE" \
    "${API_BASE}/ar-io/admin/export-parquet/status" \
    -H "Authorization: Bearer ${ADMIN_API_KEY}")
  BODY=$(cat "$BODY_FILE")
  rm -f "$BODY_FILE"

  if [[ "$HTTP_CODE" != "200" ]]; then
    echo "Error: Failed to get export status (HTTP $HTTP_CODE): $BODY" >&2
    exit 1
  fi

  STATUS=$(echo "$BODY" | python3 -c "import sys,json; print(json.load(sys.stdin).get('status',''))" 2>/dev/null || echo "")

  case "$STATUS" in
    completed)
      DURATION=$(echo "$BODY" | python3 -c "import sys,json; print(json.load(sys.stdin).get('durationInSeconds','?'))" 2>/dev/null || echo "?")
      echo "Export completed successfully in ${DURATION}s"
      echo "Output directory: $OUTPUT_DIR"
      break
      ;;
    not_started)
      echo "Error: Export status reset to 'not_started' after submission. The core process may have restarted." >&2
      exit 1
      ;;
    errored)
      ERROR_MSG=$(echo "$BODY" | python3 -c "import sys,json; print(json.load(sys.stdin).get('error','unknown'))" 2>/dev/null || echo "unknown")
      echo "Error: Export failed: $ERROR_MSG" >&2
      exit 1
      ;;
    running)
      echo "  Still running..."
      ;;
    *)
      echo "  Status: $STATUS"
      ;;
  esac
done

# Post-processing: verify counts
if $VERIFY_COUNT; then
  require_commands duckdb sqlite3 || exit 1

  echo "Verifying exported data counts..."
  CORE_DB="${CORE_DB_PATH:-data/sqlite/core.db}"
  BUNDLES_DB="${BUNDLES_DB_PATH:-data/sqlite/bundles.db}"

  # Count blocks
  SQLITE_BLOCKS=$(sqlite3 "$CORE_DB" "SELECT COUNT(*) FROM stable_blocks WHERE height BETWEEN $START_HEIGHT AND $END_HEIGHT;")
  PARQUET_BLOCKS=$(duckdb -csv -noheader -c "SELECT COUNT(*) FROM read_parquet('$OUTPUT_DIR/blocks/data/**/*.parquet', hive_partitioning=false);" 2>/dev/null || echo "0")

  if [[ "$SQLITE_BLOCKS" != "$PARQUET_BLOCKS" ]]; then
    echo "  ERROR: Block count mismatch! SQLite: $SQLITE_BLOCKS, Parquet: $PARQUET_BLOCKS" >&2
  else
    echo "  Blocks: $PARQUET_BLOCKS (matches SQLite)"
  fi

  # Count L2 transactions
  SQLITE_L2=$(sqlite3 "$BUNDLES_DB" "SELECT COUNT(*) FROM stable_data_items WHERE height BETWEEN $START_HEIGHT AND $END_HEIGHT;")
  PARQUET_L2=$(duckdb -csv -noheader -c "SELECT COUNT(*) FROM read_parquet('$OUTPUT_DIR/transactions/data/**/*.parquet', hive_partitioning=false) WHERE is_data_item = true;" 2>/dev/null || echo "0")

  if [[ "$SQLITE_L2" != "$PARQUET_L2" ]]; then
    echo "  ERROR: L2 transaction count mismatch! SQLite: $SQLITE_L2, Parquet: $PARQUET_L2" >&2
  else
    echo "  L2 Transactions: $PARQUET_L2 (matches SQLite)"
  fi

  echo "Verification complete."
fi

# Post-processing: generate Iceberg metadata
if $GENERATE_ICEBERG; then
  echo "Generating Apache Iceberg metadata..."
  if command -v python3 >/dev/null 2>&1; then
    if python3 -c "import pyiceberg" 2>/dev/null; then
      ICEBERG_CMD=(python3 "$SCRIPT_DIR/generate-iceberg-metadata" --datasets-dir "$OUTPUT_DIR")
      if [ -n "$ICEBERG_ROOT" ]; then
        ICEBERG_CMD+=(--datasets-root "$ICEBERG_ROOT")
        echo "  Using datasets root: $ICEBERG_ROOT"
      fi

      if "${ICEBERG_CMD[@]}"; then
        echo "  Iceberg metadata generated successfully"
      else
        echo "  Warning: Iceberg metadata generation failed, but export data is intact" >&2
      fi
    else
      echo "  Warning: PyIceberg not installed. Run: pip install 'pyiceberg[pyarrow,duckdb,sql]'" >&2
    fi
  else
    echo "  Warning: Python3 not available, cannot generate Iceberg metadata" >&2
  fi
fi

exit 0
